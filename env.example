# Groq API key
# https://console.groq.com adresinden alabilirsin
GROQ_API_KEY=

# GitHub Personal Access Token
# Gerekli izinler: Contents (read/write), Actions (write)
# https://github.com/settings/tokens/new adresinden oluştur
GH_PAT=

# Repo adı (kullanıcıadı/repo-adı formatında)
GH_REPO=kullaniciadi/eptran

# Branch (varsayılan: main)
GH_BRANCH=main
